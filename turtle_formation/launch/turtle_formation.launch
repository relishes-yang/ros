<launch>
    <!-- 启动乌龟仿真器（默认生成 turtle1） -->
    <node name="turtlesim_node" pkg="turtlesim" type="turtlesim_node" output="screen"/>

    <!-- 键盘控制 turtle1 -->
    <node name="teleop_turtle" pkg="turtlesim" type="turtle_teleop_key" output="screen"/>

    <!-- 编队节点（代码内自动生成 turtle2、turtle3） -->
    <node name="turtle_formation" pkg="turtle_formation" type="turtle_formation.py" output="screen"/>
</launch>
